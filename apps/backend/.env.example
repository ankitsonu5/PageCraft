PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/pagepulse_db
APP_BASE_URL=https://yourdomain.com
FRONTEND_URL=http://localhost:4200

ADMIN_EMAIL=admin@yourcompany.in
ADMIN_PASSWORD=your-secure-password-here

JWT_SECRET=change-this-to-a-very-long-random-string-minimum-32-chars
JWT_EXPIRES_IN=30d

# Google Analytics 4
# 1. Google Cloud Console → APIs → Enable: Analytics Admin API + Analytics Data API
# 2. IAM → Service Accounts → Create → Download JSON key
# 3. Rename to ga4-service-account.json → put in apps/backend/secrets/
# 4. analytics.google.com → Account → Add service account email as Editor
GA4_SERVICE_ACCOUNT_KEY_PATH=./secrets/ga4-service-account.json
GA4_ACCOUNT_NAME=accounts/XXXXXXXXX
