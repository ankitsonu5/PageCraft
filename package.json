{
  "name": "pagecraft",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "nodemon apps/backend/src/server.js",
    "dev:frontend": "cd apps/frontend && npx ng serve --proxy-config proxy.conf.json",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"nodemon apps/backend/src/server.js\" \"cd apps/frontend && npx ng serve --proxy-config proxy.conf.json\"",
    "build": "cd apps/frontend && npx ng build --configuration=production",
    "start": "node apps/backend/src/server.js",
    "seed": "node apps/backend/prisma/seed.js",
    "migrate": "cd apps/backend && npx prisma migrate dev",
    "studio": "cd apps/backend && npx prisma studio",
    "deploy": "npm run build && pm2 restart pagepulse || pm2 start ecosystem.config.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "./apps/backend/tests/setup.js"
    ]
  },
  "dependencies": {
    "@google-analytics/admin": "^4.9.0",
    "@google-analytics/data": "^4.8.0",
    "@prisma/client": "^5.12.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "8.3.2",
    "geoip-lite": "^1.4.10",
    "googleapis": "^140.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "ua-parser-js": "^1.0.37"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.12.0",
    "supertest": "^7.2.2"
  }
}
